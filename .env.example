# Qwen API 配置
QWEN_API_KEY=your-qwen-api-key
QWEN_CHAT_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBED_MODEL=text-embedding-v4
QWEN_CHAT_MODEL=qwen-plus
EMBED_DIM=1024

# 向量数据库
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=rag_collection

# 数字分身
CHARACTER_NAME=Unknown Character
CHARACTER_ERA=Unknown Era
CHARACTER_PERSONALITY=Unknown Personality
CHARACTER_SPEAKING_STYLE=Unknown Speaking Style
CHARACTER_BACKGROUND=Unknown Background

# API 服务
API_HOST=0.0.0.0
API_PORT=8000

# 数据摄入
CHUNK_SIZE=600
CHUNK_OVERLAP=50
MAX_CONCURRENT_INGEST=10

# 日志
LOG_LEVEL=INFO