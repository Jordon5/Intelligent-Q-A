# 环境配置文件示例
# 复制此文件为 .env 并填入实际值

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Qwen API 配置
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 文件上传配置
MAX_FILE_SIZE=104857600  # 100MB
CHUNK_SIZE=5242880  # 5MB

# 日志配置
LOG_LEVEL=INFO